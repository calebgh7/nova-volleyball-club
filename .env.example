# ============================================================================
# Nova Volleyball Club — Environment Variables (TEMPLATE)
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local — it holds secrets. (.gitignore already excludes it.)
# ============================================================================

# --- Supabase (from your Supabase project: Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key — bypasses row-level security. NEVER expose to the browser.
# Used by webhooks / bulk sends. Leave unset until needed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (Phase 2) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@aznova.org

# --- Claude (Anthropic) API — powers the AI assistants ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
