# ============================================================================
# Nova Volleyball Club — Environment Variables (TEMPLATE)
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local — it holds secrets. (.gitignore already excludes it.)
# ============================================================================

# --- Supabase (from your Supabase project: Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key — bypasses row-level security. NEVER expose to the browser.
# Used by trusted server tasks (bulk email sends, imports). Leave unset until needed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email: Google Workspace SMTP for aznova.org (Phase 1) ---
# Auth emails (signup/reset) are sent by Supabase using the SMTP you configure
# in the Supabase dashboard. These app-level vars are for club announcements
# the app sends itself in Phase 1. Use a Workspace account + App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=club@aznova.org
SMTP_PASSWORD=your-workspace-app-password
EMAIL_FROM=club@aznova.org

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# NOT USED (by decision, 2026-06-22):
#   * Payments are tracked, not processed in-app (Venmo/Zelle/check/Square) — no Stripe.
#   * No SMS — no Twilio.
#   * No third-party email service — no Resend.
#   * In-app AI assistants deferred — no Anthropic/OpenAI key.
# If any of these are adopted later, add their keys here.
# ----------------------------------------------------------------------------
